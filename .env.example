# ============================================================
# PontQL — Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Required: PromptQL Authentication ---

# Your Hasura Cloud Personal Access Token
# Get one at: https://cloud.hasura.io/account-settings/access-tokens
PROMPTQL_PAT=

# Your phone number with country code (no + or spaces, e.g. 61412345678)
MY_NUMBER=

# --- Optional: PromptQL Settings ---

# Specific project name (default: first project found)
# PROMPTQL_PROJECT=my-project

# Room name for threads (default: whatsapp)
# PROMPTQL_ROOM=whatsapp

# --- Access Control (3 independent axes — all configurable in dashboard) ---

# WHERE: Listen in DMs? (default: true)
LISTEN_DM=true

# WHERE: Listen in groups? (empty=none, *=all, or comma-separated names)
LISTEN_GROUPS=

# WHO: me | contacts | anyone (default: me — safest)
WHO=me

# WHO: Allowed phone numbers when WHO=contacts
ALLOWED_CONTACTS=

# TRIGGER: Wake word required? (empty=no, or set e.g. "pql")
WAKE_WORD=

# --- Session ---
SESSION_TIMEOUT=10

# --- Debug ---
DEBUG=false

# --- Chrome (auto-detected, override if needed) ---
# CHROME_PATH=/usr/bin/google-chrome-stable
